# GitHub Deployment Configuration
# Copy this file to .env and fill in your values

# Your GitHub username (e.g., "johndoe")
GITHUB_USERNAME=

# Your repository name (e.g., "trace-analyzer")
GITHUB_REPO=

# GitHub type: "public" for github.com or "ibm" for github.ibm.com
GITHUB_TYPE=public

# Your GitHub Personal Access Token (for pushing code)
# Create at: https://github.com/settings/tokens (public)
#        or: https://github.ibm.com/settings/tokens (IBM)
# Required scopes: repo, workflow
GITHUB_TOKEN=

# Optional: Custom branch name (default: main)
GITHUB_BRANCH=main

# Optional: Your email for git commits
GIT_EMAIL=

# Optional: Your name for git commits
GIT_NAME=